        <property name="autoIncrement" value="true"/>

    <!--
        Added the entity Acl.
    -->
    <changeSet id="20240123040728-1" author="jhipster">
        <createTable tableName="acl">
            <column name="id_acl" type="bigint" autoIncrement="${autoIncrement}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="form_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="email" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="status" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="created_by" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="role" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="org_in" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="cust_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="created_date" type="datetime">
                <constraints nullable="true" />
            </column>
            <column name="last_modified_by" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="last_modified_date" type="datetime">
                <constraints nullable="true" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
        <dropDefaultValue tableName="acl" columnName="created_date" columnDataType="datetime"/>
        <dropDefaultValue tableName="acl" columnName="last_modified_date" columnDataType="datetime"/>
    </changeSet>

    <changeSet id="20240123040728-1-relations" author="jhipster">

    </changeSet>

    <changeSet id="change_type_aclId" author="ducnv88">
        <sql>ALTER TABLE acl MODIFY  id_acl varchar(255);</sql>
    </changeSet>
    <changeSet id="change_type_formId_acl" author="ducnv88">
        <sql>ALTER TABLE acl MODIFY  form_id varchar(255);</sql>
    </changeSet>

